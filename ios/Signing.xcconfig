// Signing configuration (committed, no personal data).
// Your Apple Developer Team ID is NOT stored here — it lives in
// `Signing.local.xcconfig` (gitignored), pulled in by the optional include
// below. Copy `Signing.local.xcconfig.example` to `Signing.local.xcconfig`
// and set DEVELOPMENT_TEAM. If absent, signing falls back to no team
// (fine for the simulator; pick a team in Signing & Capabilities for a device).
DEVELOPMENT_TEAM =
#include? "Signing.local.xcconfig"
